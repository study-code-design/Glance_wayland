{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "Glance",
  "version": "0.2.5",
  "identifier": "com.harukaon.glance",
  "build": {
    "frontendDist": "../ui"
  },
  "app": {
    "macOSPrivateApi": true,
    "withGlobalTauri": true,
    "security": {
      "csp": null
    },
    "windows": [
      {
        "label": "main",
        "title": "Glance",
        "width": 420,
        "height": 400,
        "resizable": false,
        "center": true,
        "minWidth": 420,
        "minHeight": 400,
        "decorations": true,
        "shadow": true
      }
    ]
  },
  "bundle": {
    "active": true,
    "icon": ["icons/icon.png", "icons/icon.ico"],
    "targets": "all",
    "macOS": {
      "signingIdentity": "-"
    }
  },
  "plugins": {
    "global-shortcut": null,
    "autostart": null
  }
}
